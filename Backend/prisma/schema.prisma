// Connect Prisma to PostgreSQL server

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums are fixed values.
// They improve data consistency.
//
// Example:
// Instead of:
// status = "working"
// we use
// IN_PROGRESS

// User Role
enum Role {
  OWNER
  ADMIN
  MEMBER
}

// Project Status
enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ARCHIVED
}

// Task Priority
enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Task Status
enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

// AI Feature Type
enum AIType {
  TASK_GENERATION
  SPRINT_SUMMARY
  MEETING_NOTES
}

// Invitation Status
enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Organizations owned by this user.
  ownedOrganizations Organization[] @relation("OrganizationOwner")

  // Organizations where this user is a member.
  organizationMemberships OrganizationMember[]

  // Workspaces where this user belongs.
  workspaceMemberships WorkspaceMember[]

  // Tasks created by this user.
  createdTasks Task[] @relation("CreatedTasks")

  // Tasks assigned to this user.
  assignedTasks Task[] @relation("AssignedTasks")

  // Comments written by this user.
  comments Comment[]

  // Notifications received by this user.
  notifications Notification[]

  // Refresh tokens used for login sessions.
  refreshTokens RefreshToken[]

  // AI prompts generated by this user.
  aiHistory AIHistory[]

  // Activity logs generated by this user.
  activities Activity[]

  // OAuth account (Google Login etc.)
  account Account?
}

// ORGANIZATION MODEL
model Organization {
  // Primary Key
  id String @id @default(uuid())

  // Organization Name
  name String

  // Owner ID
  ownerId String

  owner User @relation("OrganizationOwner", fields: [ownerId], references: [id])

  // Organization Members
  members OrganizationMember[]

  // Organization Workspaces
  workspaces Workspace[]

  // Created Timestamp
  createdAt DateTime @default(now())
}

// ORGANIZATION MEMBER
model OrganizationMember {
  // Primary Key
  id String @id @default(uuid())

  // Foreign Key → Organization
  organizationId String

  // Foreign Key → User
  userId String

  // User role inside organization
  role Role @default(MEMBER)

  // Organization Relation
  organization Organization @relation(fields: [organizationId], references: [id])

  // User Relation
  user User @relation(fields: [userId], references: [id])

  // Joined Date
  joinedAt DateTime @default(now())

  // Composite Unique Key
  @@unique([organizationId, userId])
}

// WORKSPACE
model Workspace {
  // Primary Key
  id String @id @default(uuid())

  // Workspace Name
  name String

  // Foreign Key
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])

  // Workspace Members
  members WorkspaceMember[]

  // Projects
  projects Project[]

  // Meetings
  meetings Meeting[]

  // Activity Logs
  activities Activity[]

  // Created Timestamp
  createdAt DateTime @default(now())
}

// WORKSPACE MEMBER MODEL
model WorkspaceMember {
  // Unique ID
  id String @id @default(uuid())

  // User foreign key
  userId String

  // Workspace foreign key
  workspaceId String

  // Permission level inside workspace
  role Role @default(MEMBER)

  // User Relationship
  user User @relation(fields: [userId], references: [id])

  // Workspace.id
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  // When user joined workspace
  joinedAt DateTime @default(now())

  // Prevent duplicate membership
  @@unique([userId, workspaceId])
}

model Task {
  // Primary key
  id String @id @default(uuid())

  // Task title
  title String

  // Detailed explanation
  description String?

  status   TaskStatus @default(TODO)
  position Float

  // Priority level
  priority Priority @default(MEDIUM)

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedTasks", fields: [assignedToId], references: [id])

  // Task Creator
  createdById String
  createdBy   User   @relation("CreatedTasks", fields: [createdById], references: [id])

  // Calendar feature
  dueDate DateTime?

  // Future comments
  comments Comment[]

  // Future attachments
  attachments Attachment[]

  createdAt DateTime @default(now())
}

model Project {
  // Primary key
  id String @id @default(uuid())

  // Project name
  name String

  // Optional project description
  description String?

  // Project lifecycle status
  status ProjectStatus @default(PLANNING)

  // Workspace reference
  workspaceId String

  // Workspace Relation
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  // Project Tasks
  tasks Task[]

  createdAt DateTime @default(now())
}

model Comment {
  // Unique identifier
  id String @id @default(uuid())

  message String

  // Task reference
  taskId String

  // User who wrote comment
  userId String

  // Task Relationship
  task Task @relation(fields: [taskId], references: [id])

  // User Relationship
  user User @relation(fields: [userId], references: [id])

  // When comment was created
  createdAt DateTime @default(now())
}

// ATTACHMENT MODEL
model Attachment {
  // Primary key
  id String @id @default(uuid())

  fileName String
  fileUrl  String

  // Useful for deleting files later.
  publicId String?

  // Task reference
  taskId String

  // Task Relationship
  task Task @relation(fields: [taskId], references: [id])

  // Upload timestamp
  uploadedAt DateTime @default(now())
}

model Meeting {
  // Primary key
  id String @id @default(uuid())

  // Meeting title
  title String

  transcript String?

  // AI generated summary
  summary String?

  // Workspace reference
  workspaceId String

  // Workspace Relationship
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  createdAt DateTime @default(now())
}

// NOTIFICATION MODEL
model Notification {
  // Unique identifier
  id String @id @default(uuid())

  // Notification title
  title String

  // Notification message
  message String

  // Whether user has read it
  isRead Boolean @default(false)

  // User reference
  userId String

  // User Relationship
  user User @relation(fields: [userId], references: [id])

  // Created time
  createdAt DateTime @default(now())
}

// REFRESH TOKEN MODEL
model RefreshToken {
  // Primary key
  id String @id @default(uuid())

  // Actual token value
  token String @unique

  // Owner of this token
  userId String

  // User Relationship
  user User @relation(fields: [userId], references: [id])

  // Token expiry date
  expiresAt DateTime
}

model Account {
  // Primary key
  id String @id @default(uuid())

  // User reference
  userId String @unique

  // Provider name
  provider String

  // ID received from provider
  providerAccountId String

  // User Relationship
  user User @relation(fields: [userId], references: [id])

  // Same provider account
  // cannot connect twice.
  @@unique([provider, providerAccountId])
}

// AI HISTORY MODEL
model AIHistory {
  // Primary key
  id String @id @default(uuid())

  // AI feature used
  type AIType

  // User prompt/input
  input String

  // AI generated response
  output String

  // User who requested AI
  userId String

  // User Relationship
  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Activity {
  // Primary key
  id String @id @default(uuid())

  // Action performed
  action String

  // User who performed action
  userId String

  // Workspace where action happened
  workspaceId String

  // User Relationship
  user User @relation(fields: [userId], references: [id])

  // Workspace Relationship
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  createdAt DateTime @default(now())
}
